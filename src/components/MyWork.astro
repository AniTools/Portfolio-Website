---
import ProjectCard from "./ProjectCard.astro";
import { db } from "../lib/firebase.js";
import { collection, getDocs } from "firebase/firestore";

let projects: any[] = [];

try {
  const querySnapshot = await getDocs(collection(db, "case_studies"));
  projects = querySnapshot.docs.map(doc => doc.data());
  projects.sort((a, b) => {
    if (a.name === "The Mob Squad") return -1;
    if (b.name === "The Mob Squad") return 1;
    return 0;
  });
} catch (e) {
  console.error("Error loading projects from Firestore:", e);
}
---

<section id="my-work" class="section relative">
  <h2 class="section-title">My Work</h2>

  <div class="relative w-full max-w-6xl mx-auto">

    <button id="prev-btn" aria-label="Previous" class="carousel-arrow" style="left:0">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>

    <button id="next-btn" aria-label="Next" class="carousel-arrow" style="right:0">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>

    <div
      id="carousel"
      class="flex overflow-x-auto scroll-smooth snap-x snap-mandatory no-scrollbar mx-8"
    >
      {projects.map((project) => (
        <div class="flex-shrink-0 w-full sm:w-1/2 lg:w-1/3 snap-center px-4">
          <ProjectCard project={project} />
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #ff715d;
    opacity: 0.5;
    padding: 6px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .carousel-arrow:hover {
    opacity: 1;
    transform: translateY(-50%) scale(1.15);
  }
</style>

<script>
  const carousel = document.getElementById("carousel") as HTMLElement | null;
  const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement | null;
  const nextBtn = document.getElementById("next-btn") as HTMLButtonElement | null;

  if (carousel && prevBtn && nextBtn) {
    const el = carousel;
    const cards = el.children.length;
    let index = 0;

    function scrollToIndex(i: number) {
      index = (i + cards) % cards;
      const card = el.children[index] as HTMLElement;
      el.scrollTo({ left: card.offsetLeft, behavior: "smooth" });
    }

    prevBtn.addEventListener("click", () => scrollToIndex(index - 1));
    nextBtn.addEventListener("click", () => scrollToIndex(index + 1));

    // Auto-advance
    setInterval(() => scrollToIndex(index + 1), 4000);
  }
</script>
